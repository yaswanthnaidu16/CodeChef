# no of notes it take to obtain the amount given thriugh denominations
for _ in range(int(input())):
    n = int(input())
    count = 0
    count += n // 100
    n %= 100
    count += n // 50
    n %= 50
    count += n // 10
    n %= 10
    count += n // 5
    n %= 5
    count += n // 2
    n %= 2
    count += n // 1
    print(count)
