#no of steps it require to make both integers equal
import math
for _ in range(int(input())):
    x, y = map(int, input().split())
    if x <= y:
        d = y - x
        if d % 2 == 0:
            print(d // 2)
        else:
            print(d // 2 + 2)
    else:
        print(math.ceil((x - y) / 2))
