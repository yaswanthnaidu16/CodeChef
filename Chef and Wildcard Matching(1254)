#To check whether both strings can be equal with "?" in the strings
for _ in range(int(input())):
    s1 = input()
    s2 = input()
    ok = True
    for i in range(len(s1)):
        if s1[i] != s2[i] and s1[i] != '?' and s2[i] != '?':
            ok = False
            break
    print("Yes" if ok else "No")
